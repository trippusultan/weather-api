# ── Weather API — .env (copy from .env.example as .env) ─────────────
# Environment variables for the weather proxy service.

# ─ Visual Crossing ────────────────────────────────────────────────────
# Get your free key at https://www.visualcrossing.com/sign-up
VC_API_KEY=

# ─ Demo Mode (no API key needed) ─────────────────────────────────────
# Set DEMO=true to use the built-in hardcoded weather response.
# Perfect for testing the API structure without a key.
DEMO=true

# ─ Redis (optional — in-memory fallback when not set) ────────────────
# Local:
#   sudo apt install redis-server  &&  sudo service redis-server start
# Docker:
#   docker run -d -p 6379:6379 redis:alpine
# For production / shared-cache deployments, point REDIS_URL at it.
REDIS_URL=

# ─ Server ────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ─ Cache ────────────────────────────────────────────────────────────
# TTL in seconds — default 12 hours
CACHE_TTL=43200

# ─ Upstream ─────────────────────────────────────────────────────────
# Visual Crossing request timeout (seconds)
VC_TIMEOUT=8
